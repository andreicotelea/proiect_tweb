{
  "name": "react-axios-provider-kit",
  "version": "0.1.1",
  "description": "Configurable Axios Provider for React with JWT auth, refresh token, concurrency control, and pluggable storage",
  "keywords": [
    "react",
    "axios",
    "axios-provider",
    "react-provider",
    "auth",
    "jwt",
    "refresh-token",
    "http-client",
    "typescript"
  ],
  "author": "Mihai Musteata",
  "license": "MIT",
  "homepage": "https://github.com/MihaiMusteata/react-axios-provider-kit",
  "repository": {
    "type": "git",
    "url": "https://github.com/MihaiMusteata/react-axios-provider-kit.git"
  },
  "bugs": {
    "url": "https://github.com/MihaiMusteata/react-axios-provider-kit/issues"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(lint not configured)\"",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "axios": ">=1.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "axios": "^1.6.0",
    "react": "^19.2.3",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
